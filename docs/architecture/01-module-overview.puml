@startuml
title Proximity Crafting - Module Overview
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle

package "common" as Common {
  component "Behavior and state" as CommonBehavior
  component "Contracts and shared payloads" as CommonContracts
  component "Config semantics and descriptors" as CommonConfig
}

package "forge" as Forge {
  component "Runtime adapters" as ForgeAdapters
  component "Transport and bootstrap" as ForgeBootstrap
  component "UI and compat\n(JEI / EMI / SB)" as ForgeCompat
}

package "fabric" as Fabric {
  component "Runtime adapters" as FabricAdapters
  component "Transport and bootstrap" as FabricBootstrap
  component "UI host" as FabricUi
  component "Compat placeholders\n(overlay integrations pending)" as FabricCompat
}

package "neoforge" as NeoForge {
  component "Runtime adapters" as NeoForgeAdapters
  component "Transport and bootstrap" as NeoForgeBootstrap
  component "UI host" as NeoForgeUi
  component "Vanilla-book-only target" as NeoForgeScope
}

CommonBehavior -down-> CommonContracts
CommonConfig -down-> CommonContracts

ForgeAdapters ..> CommonBehavior
ForgeBootstrap ..> CommonContracts
ForgeCompat ..> CommonBehavior

FabricAdapters ..> CommonBehavior
FabricBootstrap ..> CommonContracts
FabricUi ..> CommonBehavior
FabricCompat ..> CommonContracts

NeoForgeAdapters ..> CommonBehavior
NeoForgeBootstrap ..> CommonContracts
NeoForgeUi ..> CommonBehavior
NeoForgeScope ..> CommonContracts

note bottom of Common
common owns reusable behavior, state machines,
contracts, shared payloads, config semantics,
and registry/bootstrap descriptors.
end note

note bottom of Forge
Forge is the reference runtime and owns
loader-specific bootstrap, transport,
runtime adapters, and current compat.
end note

note bottom of Fabric
Fabric 1.20.1 is stable for the vanilla
recipe book path. Overlay integrations are
still pending.
end note

note bottom of NeoForge
NeoForge 1.20.1 is intentionally capped at
the vanilla recipe book runtime path.
JEI, EMI, and backpack compat remain deferred.
end note
@enduml
