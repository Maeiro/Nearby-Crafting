{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}+fabric-${minecraft_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "license": "${mod_license}",
  "icon": "img/icon256.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.maeiro.proximitycrafting.fabric.ProximityCraftingFabric"
    ],
    "client": [
      "dev.maeiro.proximitycrafting.fabric.client.ProximityCraftingFabricClient"
    ]
  },
  "mixins": [
    "proximitycrafting.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.11",
    "minecraft": "~${minecraft_version}",
    "architectury": ">=${architectury_api_version}"
  }
}
